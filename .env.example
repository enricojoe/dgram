# Docker Compose environment — copy to ".env" and adjust.
# Compose auto-loads ".env" from this directory (next to docker-compose.yml).

# --- Published host ports -------------------------------------------------
# Host port -> container. Container-internal ports stay fixed.
POSTGRES_PORT=5434   # localhost:5434 -> postgres:5432
BACKEND_PORT=8080    # localhost:8080 -> backend:8080
FRONTEND_PORT=5173   # localhost:5173 -> frontend (nginx listens here too)

# --- Postgres -------------------------------------------------------------
POSTGRES_USER=dgram
POSTGRES_PASSWORD=dgram
POSTGRES_DB=dgram

# --- Backend --------------------------------------------------------------
JWT_SECRET=dev-secret-change-me
CORS_ORIGIN=http://localhost:5173
