# Copy to .env (or .env.local) and adjust as needed.
# VITE_-prefixed vars are baked into the client bundle, so do NOT put secrets here.

# Base URL the axios client targets. Defaults to "/api" (proxied to the backend in dev).
VITE_API_BASE_URL=/api

# Dev-only: where Vite proxies "/api" requests during `npm run dev`.
VITE_API_PROXY_TARGET=http://localhost:8080
